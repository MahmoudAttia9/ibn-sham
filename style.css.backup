@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&family=Cinzel:wght@400;600;700&display=swap');

/* --- التنسيقات الأساسية --- */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Tajawal', sans-serif;
    background: #0a0a0a;
    min-height: 100vh;
    /* تم تعديل العرض ليسمح بالسكرول */
    display: block; 
    padding: 20px;
    overflow-x: hidden; /* منع السكرول الأفقي */
    position: relative;
    color: #fff;
}

/* خلفية متحركة */
body::before {
    content: '';
    position: fixed; /* جعل الخلفية ثابتة أثناء السكرول */
    top: 0; left: 0; width: 100%; height: 100%;
    background: 
        radial-gradient(circle at 20% 30%, rgba(220, 20, 60, 0.15) 0%, transparent 50%),
        radial-gradient(circle at 80% 70%, rgba(139, 0, 0, 0.15) 0%, transparent 50%);
    animation: backgroundShift 10s ease-in-out infinite;
    z-index: -1;
}

@keyframes backgroundShift {
    0%, 100% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.1) rotate(5deg); }
}

/* --- تنسيقات الغلاف (Cover Styles) --- */
.cover-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 90vh; /* الغلاف يأخذ معظم الشاشة في البداية */
    margin-bottom: 50px;
}

.menu-cover {
    background: linear-gradient(135deg, rgba(20, 20, 20, 0.95) 0%, rgba(40, 10, 10, 0.95) 100%);
    border: 2px solid rgba(220, 20, 60, 0.3);
    border-radius: 40px;
    padding: 50px 35px;
    max-width: 480px;
    width: 100%;
    text-align: center;
    box-shadow: 
        0 30px 90px rgba(0, 0, 0, 0.8),
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        0 0 100px rgba(220, 20, 60, 0.2);
    position: relative;
    z-index: 1;
    backdrop-filter: blur(20px);
    overflow: hidden;
}

/* تأثير اللمعان على الغلاف */
.menu-cover::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(45deg, transparent 30%, rgba(220, 20, 60, 0.03) 50%, transparent 70%);
    animation: shine 3s ease-in-out infinite;
    pointer-events: none;
}
@keyframes shine {
    0% { transform: translateX(-100%) translateY(-100%); }
    100% { transform: translateX(100%) translateY(100%); }
}

/* زخارف الزوايا */
.corner-decoration {
    position: absolute; width: 80px; height: 80px;
    border: 2px solid rgba(220, 20, 60, 0.4);
}
.corner.top-left { top: 15px; left: 15px; border-right: none; border-bottom: none; border-radius: 20px 0 0 0; }
.corner.top-right { top: 15px; right: 15px; border-left: none; border-bottom: none; border-radius: 0 20px 0 0; }
.corner.bottom-left { bottom: 15px; left: 15px; border-right: none; border-top: none; border-radius: 0 0 0 20px; }
.corner.bottom-right { bottom: 15px; right: 15px; border-left: none; border-top: none; border-radius: 0 0 20px 0; }

/* اللوجو */
.logo-container {
    position: relative; z-index: 2; margin-bottom: 35px;
    animation: logoEntrance 1.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes logoEntrance {
    0% { opacity: 0; transform: translateY(-50px) scale(0.5) rotate(-10deg); }
    100% { opacity: 1; transform: translateY(0) scale(1) rotate(0deg); }
}
.logo-wrapper {
    background: radial-gradient(circle, rgba(220, 20, 60, 0.15) 0%, transparent 70%);
    padding: 20px; border-radius: 50%; display: inline-block; position: relative;
}
.logo-wrapper::before {
    content: ''; position: absolute; inset: -5px; border-radius: 50%;
    background: linear-gradient(45deg, #DC143C, #8B0000, #DC143C);
    opacity: 0.3; filter: blur(15px); animation: glowPulse 3s ease-in-out infinite;
}
@keyframes glowPulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.1); }
}
.logo-container img { width: 220px; height: auto; filter: drop-shadow(0 15px 35px rgba(220, 20, 60, 0.4)); position: relative; z-index: 1; }

/* النصوص في الغلاف */
.restaurant-name {
    font-size: 56px; font-weight: 900;
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 50%, #FF6347 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    margin: 25px 0 15px; text-shadow: 0 0 30px rgba(255, 215, 0, 0.5);
    animation: titleEntrance 1s ease-out 0.3s both; position: relative; z-index: 2; letter-spacing: 2px;
}
@keyframes titleEntrance {
    0% { opacity: 0; transform: translateY(30px); filter: blur(10px); }
    100% { opacity: 1; transform: translateY(0); filter: blur(0); }
}
.english-name {
    font-family: 'Cinzel', serif; font-size: 22px; color: #C0C0C0; font-weight: 600; letter-spacing: 6px;
    margin-bottom: 35px; animation: titleEntrance 1s ease-out 0.5s both; position: relative; z-index: 2; text-transform: uppercase; text-shadow: 0 2px 10px rgba(192, 192, 192, 0.3);
}
.decorative-divider {
    width: 200px; height: 2px; margin: 30px auto; position: relative; animation: dividerEntrance 1s ease-out 0.7s both;
}
.decorative-divider::before {
    content: ''; position: absolute; left: 0; right: 0; height: 100%;
    background: linear-gradient(90deg, transparent, #DC143C 20%, #FFD700 50%, #DC143C 80%, transparent);
    animation: shimmer 2s ease-in-out infinite;
}
@keyframes shimmer { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }
.decorative-divider::after {
    content: '✦'; position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
    color: #FFD700; font-size: 16px; background: #0a0a0a; padding: 0 10px; animation: sparkle 2s ease-in-out infinite;
}
@keyframes sparkle {
    0%, 100% { transform: translate(-50%, -50%) rotate(0deg) scale(1); }
    50% { transform: translate(-50%, -50%) rotate(180deg) scale(1.2); }
}
@keyframes dividerEntrance { 0% { opacity: 0; transform: scaleX(0); } 100% { opacity: 1; transform: scaleX(1); } }

.menu-label-btn {
    font-size: 38px; color: #1a1a1a; font-weight: 900; margin: 30px 0; padding: 18px 40px;
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%); border-radius: 20px; display: inline-block;
    box-shadow: 0 10px 30px rgba(255, 215, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.5), inset 0 -1px 0 rgba(0, 0, 0, 0.2);
    animation: menuLabelEntrance 1s ease-out 0.9s both; position: relative; z-index: 2;
    transform-style: preserve-3d; transition: transform 0.3s ease; cursor: pointer; text-decoration: none;
}
.menu-label-btn:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 15px 40px rgba(255, 215, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.5);
}
@keyframes menuLabelEntrance {
    0% { opacity: 0; transform: translateY(30px) rotateX(90deg); }
    100% { opacity: 1; transform: translateY(0) rotateX(0deg); }
}
.subtitle {
    font-size: 18px; color: #999; margin-top: 25px; animation: subtitleEntrance 1s ease-out 1.1s both;
    position: relative; z-index: 2; letter-spacing: 1px;
}
@keyframes subtitleEntrance { 0% { opacity: 0; transform: translateY(20px); } 100% { opacity: 1; transform: translateY(0); } }

.flame-decoration {
    position: absolute; font-size: 30px; opacity: 0.6; animation: flicker 2s ease-in-out infinite;
}
.flame.left { left: 30px; top: 50%; animation-delay: 0s; }
.flame.right { right: 30px; top: 50%; animation-delay: 1s; }
@keyframes flicker {
    0%, 100% { opacity: 0.4; transform: translateY(0) scale(1); filter: hue-rotate(0deg); }
    50% { opacity: 0.8; transform: translateY(-10px) scale(1.1); filter: hue-rotate(20deg); }
}

/* --- تنسيقات تفاصيل المنيو (Menu Details Styles) --- */
.menu-details-container {
    max-width: 900px;
    margin: 0 auto 50px;
    background: rgba(20, 10, 10, 0.95);
    border: 1px solid rgba(220, 20, 60, 0.3);
    border-radius: 30px;
    padding: 30px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    backdrop-filter: blur(20px);
}

.section-banner {
    background: linear-gradient(90deg, #8B0000, #DC143C);
    color: #FFD700;
    padding: 15px;
    text-align: center;
    font-size: 28px;
    font-weight: 900;
    border-radius: 15px;
    margin: 50px 0 30px;
    position: relative;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    border-bottom: 4px solid #FFD700;
    box-shadow: 0 5px 15px rgba(220, 20, 60, 0.4);
}

/* تنسيق العناصر العادية (اسم وسعر) */
.menu-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 10px;
    border-bottom: 1px solid rgba(220, 20, 60, 0.2);
    transition: background 0.3s;
}
.menu-item:hover { background: rgba(220, 20, 60, 0.1); }
.menu-item:last-child { border-bottom: none; }

.item-info { flex-grow: 1; text-align: right; padding-left: 20px; }
.item-name { font-size: 20px; font-weight: 700; color: #eee; margin-bottom: 5px; display: block;}
.item-desc { font-size: 13px; color: #aaa; display: block; line-height: 1.4; }
.item-price { 
    font-size: 24px; font-weight: 900; color: #FFD700; 
    text-align: center; min-width: 70px;
    text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
}
.price-currency { font-size: 14px; font-weight: normal; color: #ccc; margin-right: 5px; }

/* تنسيق العناصر ذات الأسعار المتعددة (Grid Layout) */
.multi-price-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    text-align: center; color: #DC143C; font-weight: bold; font-size: 16px;
    margin-bottom: 15px; padding-bottom: 10px;
    border-bottom: 2px solid rgba(220, 20, 60, 0.3);
}
.menu-item-multi {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    align-items: center; padding: 12px 5px;
    border-bottom: 1px solid rgba(220, 20, 60, 0.2);
    transition: background 0.3s;
}
.menu-item-multi:hover { background: rgba(220, 20, 60, 0.1); }
.multi-name { font-size: 19px; font-weight: 700; color: #eee; }
.multi-price-col { font-size: 20px; font-weight: 900; color: #FFD700; text-align: center; }

/* تنسيق الفوتر */
.menu-footer {
    margin-top: 60px; text-align: center; padding: 30px;
    border-top: 3px solid #DC143C;
    background: linear-gradient(to top, rgba(220, 20, 60, 0.1), transparent);
    border-radius: 0 0 30px 30px;
}
.footer-address { font-size: 20px; margin-bottom: 20px; color: #fff; font-weight: bold;}
.footer-phones { 
    display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; 
    font-size: 22px; color: #FFD700; font-weight: 900;
}
.phone-item { display: flex; align-items: center; }
.whatsapp-icon { color: #25D366; margin-left: 10px; font-size: 26px;}

/* --- Media Queries للتجاوب --- */
@media (max-width: 768px) {
    .menu-item-multi, .multi-price-header { grid-template-columns: 1.5fr 1fr 1fr 1fr; }
    .multi-name, .item-name { font-size: 18px; }
    .multi-price-col, .item-price { font-size: 18px; }
    .section-banner { font-size: 24px; }
}
@media (max-width: 480px) {
    .cover-container { min-height: auto; padding-top: 20px;}
    .menu-cover { padding: 40px 25px; border-radius: 30px; }
    .logo-container img { width: 180px; }
    .restaurant-name { font-size: 42px; }
    .english-name { font-size: 18px; letter-spacing: 4px; }
    .menu-label-btn { font-size: 30px; padding: 15px 30px; }
    .corner-decoration { width: 60px; height: 60px; }
    .flame-decoration { font-size: 24px; }

    /* تعديلات المنيو للموبايل */
    .menu-details-container { padding: 15px; }
    .section-banner { font-size: 20px; padding: 10px; margin: 30px 0 20px; }
    .item-name { font-size: 17px; }
    .item-desc { font-size: 12px; }
    .item-price { font-size: 18px; min-width: 50px;}
    
    /* تعديل الجدول للموبايل الصغير */
    .multi-price-header { font-size: 12px; }
    .menu-item-multi { padding: 10px 0; }
    .multi-name { font-size: 15px; }
    .multi-price-col { font-size: 16px; }

    .footer-address { font-size: 16px; }
    .footer-phones { font-size: 18px; flex-direction: column; gap: 10px;}
}
